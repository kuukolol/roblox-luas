        Position   = UDim2.new(0, 36, 0, 0),
        TextSize   = 15,
        Font       = Enum.Font.GothamBold,
        TextColor3 = C.text,
    })
    self._chanHdrTitle = chanHdrTitle

    -- ── Build channels ─────────────────────────────────────────────────────
    -- Each channel = { btn, feed, feedLayout }
    local channelData  = {}
    local activeChanId = DEFAULT_CH

    local function switchChannel(id)
        activeChanId = id
        for cid, cd in pairs(channelData) do
            cd.feed.Visible = (cid == id)
            -- button style
            if cid == id then
                cd.btn.BackgroundColor3       = C.panel
                cd.btn.BackgroundTransparency = 0
                cd.btnLbl.TextColor3          = C.text
            else
                cd.btn.BackgroundColor3       = C.sidebar
                cd.btn.BackgroundTransparency = 1
                cd.btnLbl.TextColor3          = C.muted
            end
        end
        -- update header
        for _, ch in ipairs(CHANNELS) do
            if ch.id == id then
                chanHdrTitle.Text = ch.label
                break
            end
        end
    end

    for _, ch in ipairs(CHANNELS) do
        -- Sidebar button
        local btn = Instance.new("TextButton")
        btn.Size               = UDim2.new(1, 0, 0, 28)
        btn.BackgroundColor3   = C.sidebar
        btn.BackgroundTransparency = 1
        btn.AutoButtonColor    = false
