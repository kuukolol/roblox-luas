    local titleIn,_ = styledInput(spBody,{Size=UDim2.new(1,0,0,36),Position=UDim2.new(0,0,0,278),
        Default=TITLE,Placeholder="Window title...",ZIndex=10})
    titleIn:GetPropertyChangedSignal("Text"):Connect(function()
        if titleIn.Text~="" then titleLbl.Text=titleIn.Text end
    end)

    label(spBody,{Text="SERVER NAME",Size=UDim2.new(1,0,0,16),Position=UDim2.new(0,0,0,328),
        TextSize=10,Font=Enum.Font.GothamBold,TextColor3=C.muted,ZIndex=11})
    local srvIn,_ = styledInput(spBody,{Size=UDim2.new(1,0,0,36),Position=UDim2.new(0,0,0,348),
        Default=SERVER,Placeholder="Server name...",ZIndex=10})
    srvIn:GetPropertyChangedSignal("Text"):Connect(function()
        if srvIn.Text~="" then srvLbl.Text="  "..srvIn.Text end
    end)

    -- Save
    local saveBtn = Instance.new("TextButton")
    saveBtn.Size=UDim2.new(1,0,0,36); saveBtn.Position=UDim2.new(0,0,0,400)
    saveBtn.BackgroundColor3=C.accent; saveBtn.BorderSizePixel=0
    saveBtn.AutoButtonColor=false; saveBtn.Font=Enum.Font.GothamBold
    saveBtn.TextSize=13; saveBtn.TextColor3=Color3.fromRGB(255,255,255)
    saveBtn.Text="Save Changes"; saveBtn.ZIndex=11; saveBtn.Parent=spBody
    corner(saveBtn,6)
    saveBtn.MouseEnter:Connect(function() tw(saveBtn,{BackgroundColor3=Color3.fromRGB(71,82,196)},0.15) end)
    saveBtn.MouseLeave:Connect(function() tw(saveBtn,{BackgroundColor3=C.accent},0.15) end)
    saveBtn.MouseButton1Click:Connect(function()
        local nm  = nameIn.Text~="" and nameIn.Text:sub(1,24) or UNAME
        local tg  = tagIn.Text~=""  and ("#"..tagIn.Text)     or UTAG
        local ttl = titleIn.Text~="" and titleIn.Text          or TITLE
        local srv = srvIn.Text~=""   and srvIn.Text            or SERVER
        botName.Text   = nm
        botTag.Text    = tg
        titleLbl.Text  = ttl
        srvLbl.Text    = "  "..srv
        prevName.Text  = nm
        prevTag.Text   = tg
        tw(saveBtn,{BackgroundColor3=C.green},0.1)
        task.delay(0.9, function() tw(saveBtn,{BackgroundColor3=C.accent},0.3) end)
    end)

    -- Gear toggle
    local settingsOpen=false
    gearBtn.MouseButton1Click:Connect(function()
        settingsOpen=not settingsOpen
        sp.Visible=settingsOpen
        tw(gearIco,{ImageColor3=settingsOpen and C.accent or C.muted},0.15)
    end)

    return self
end

-- ─── Public API ───────────────────────────────────────────────────────────────

-- Get the feed for a specific channel id (or default if nil)
function UI:GetFeed(channelId)
    if channelId then
        local cd = self._channelData[channelId]
        return cd and cd.feed, cd and cd.feedLayout
    end
    return self._feed, self._feedLayout
end

-- Push canvas to bottom of a feed
function UI:ScrollToBottom(channelId)
    local feed = self:GetFeed(channelId)
    if feed then feed.CanvasPosition = Vector2.new(0, math.huge) end
end

-- Update timestamps (call from Heartbeat)
function UI:UpdateTimestamps()
    for _, cd in pairs(self._channelData) do
        for _, row in cd.feed:GetChildren() do
            if row:IsA("Frame") then
                local sa = row:GetAttribute("SpawnedAt")
                if sa then
                    local e = math.floor(os.clock()-sa)
                    local t
                    if e<60 then t=e.."s ago"
                    elseif e<3600 then
                        local m=math.floor(e/60); local s=e%60
                        t=s>0 and(m.."m "..s.."s ago")or(m.."m ago")
                    else t=math.floor(e/3600).."h ago" end
                    for _,l in row:GetDescendants() do
                        if l:IsA("TextLabel") and l.Name=="TimeLabel" then l.Text=t end
                    end
                end
            end
        end
    end
end

return UI
