local TweenService = game:GetService("TweenService")
local RunService   = game:GetService("RunService")
local UIS          = game:GetService("UserInputService")
local Players      = game:GetService("Players")
local LP           = Players.LocalPlayer

local C = {
    bg      = Color3.fromRGB(30,  31,  34),
    sidebar = Color3.fromRGB(35,  36,  40),
    panel   = Color3.fromRGB(43,  45,  49),
    accent  = Color3.fromRGB(88,  101, 242),
    text    = Color3.fromRGB(220, 221, 222),
    muted   = Color3.fromRGB(148, 155, 164),
    divider = Color3.fromRGB(55,  57,  63),
    green   = Color3.fromRGB(67,  181, 129),
    red     = Color3.fromRGB(240,  71,  71),
}

local function tw(obj, props, t)
    TweenService:Create(obj, TweenInfo.new(t or 0.18,
        Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end
local function corner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p
end
local function lbl(parent, props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1; l.Font = Enum.Font.GothamSemibold
    l.TextSize = 13; l.TextColor3 = C.text; l.TextXAlignment = Enum.TextXAlignment.Left
    for k, v in pairs(props or {}) do l[k] = v end
    l.Parent = parent; return l
end
local function frm(parent, props)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = C.panel; f.BorderSizePixel = 0
    for k, v in pairs(props or {}) do f[k] = v end
    f.Parent = parent; return f
end
local function divLine(parent, y)
    return frm(parent, {
        BackgroundColor3 = C.divider,
        Size = UDim2.new(1, -16, 0, 1),
        Position = UDim2.new(0, 8, 0, y or 0),
    })
end
local function imgBtn(parent, props)
    local btn = Instance.new("TextButton")
    btn.Size = props.Size or UDim2.new(0, 36, 0, 36)
    btn.Position = props.Position or UDim2.new(0, 0, 0, 0)
    btn.BackgroundTransparency = 1; btn.AutoButtonColor = false; btn.Text = ""; btn.Parent = parent
    local ico = Instance.new("ImageLabel")
    ico.Size = props.IconSize or UDim2.new(0, 16, 0, 16)
    ico.AnchorPoint = Vector2.new(0.5, 0.5); ico.Position = UDim2.new(0.5, 0, 0.5, 0)
    ico.BackgroundTransparency = 1; ico.Image = props.Image or ""; ico.ImageColor3 = props.Color or C.muted
    ico.Parent = btn
    return btn, ico
end
local function makeDraggable(handle, target)
    local drag, ds, sp
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; ds = i.Position; sp = target.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            target.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
        end
    end)
end
local function styledInput(parent, props)
    local bg = frm(parent, {
        BackgroundColor3 = Color3.fromRGB(28, 29, 32),
        Size = props.Size or UDim2.new(1, 0, 0, 38),
        Position = props.Position or UDim2.new(0, 0, 0, 0),
        ZIndex = props.ZIndex or 5,
    })
    corner(bg, 5)
    local tb = Instance.new("TextBox")
    tb.Size = UDim2.new(1, -16, 1, 0); tb.Position = UDim2.new(0, 8, 0, 0)
    tb.BackgroundTransparency = 1; tb.Font = Enum.Font.Gotham; tb.TextSize = 13
    tb.TextColor3 = C.text; tb.PlaceholderColor3 = C.muted
    tb.PlaceholderText = props.Placeholder or ""; tb.Text = props.Default or ""
    tb.TextXAlignment = Enum.TextXAlignment.Left; tb.ClearTextOnFocus = false
    tb.TextEditable = true; tb.ZIndex = (props.ZIndex or 5) + 1; tb.Parent = bg
    tb.Focused:Connect(function() tw(bg, {BackgroundColor3 = Color3.fromRGB(50, 52, 80)}, 0.15) end)
    tb.FocusLost:Connect(function() tw(bg, {BackgroundColor3 = Color3.fromRGB(28, 29, 32)}, 0.15) end)
    return tb, bg
end

-- ─── Resizable window ────────────────────────────────────────────────────────
-- Adds invisible drag handles on edges/corners of win.
-- AnchorPoint is (0.5, 0) so:
--   width changes expand BOTH sides equally (center-anchored)
--   height changes only affect the bottom
-- Handles: bottom-right corner, bottom-left corner, bottom edge, right edge, left edge
local function makeResizable(win, minW, minH)
    minW = minW or 400
    minH = minH or 260

    -- Each handle: { pos, size, dx, dy }
    --   dx: +1 = right drag grows width, -1 = left drag grows width, 0 = no width change
    --   dy: +1 = down drag grows height, 0 = no height change
    local EDGE = 6  -- px thickness of edge handles
    local handles = {
        -- Corners
        { name="BR", pos=UDim2.new(1,-EDGE,1,-EDGE), size=UDim2.new(0,EDGE*2,0,EDGE*2), dx= 1, dy=1 },
        { name="BL", pos=UDim2.new(0,-EDGE,1,-EDGE), size=UDim2.new(0,EDGE*2,0,EDGE*2), dx=-1, dy=1 },
        -- Edges
        { name="B",  pos=UDim2.new(0,EDGE,  1,-EDGE), size=UDim2.new(1,-EDGE*2,0,EDGE*2), dx=0, dy=1 },
        { name="R",  pos=UDim2.new(1,-EDGE, 0,EDGE),  size=UDim2.new(0,EDGE*2, 1,-EDGE*2), dx=1, dy=0 },
        { name="L",  pos=UDim2.new(0,-EDGE, 0,EDGE),  size=UDim2.new(0,EDGE*2, 1,-EDGE*2), dx=-1, dy=0 },
    }

    for _, h in ipairs(handles) do
        local handle = Instance.new("TextButton")
        handle.Name = "ResizeHandle_" .. h.name
        handle.Size = h.size
        handle.Position = h.pos
        handle.BackgroundTransparency = 1
        handle.AutoButtonColor = false
        handle.Text = ""
        handle.ZIndex = 50  -- above everything so it always receives input
        handle.Parent = win

        -- Show a subtle accent dot on corners so user knows it's draggable
        if h.name == "BR" or h.name == "BL" then
            local dot = Instance.new("Frame")
            dot.Size = UDim2.new(0, 6, 0, 6)
            dot.AnchorPoint = Vector2.new(0.5, 0.5)
            dot.Position = UDim2.new(0.5, 0, 0.5, 0)
            dot.BackgroundColor3 = C.divider
            dot.BorderSizePixel = 0
            dot.ZIndex = 51
            dot.Parent = handle
            corner(dot, 3)
            handle.MouseEnter:Connect(function() tw(dot, {BackgroundColor3 = C.accent}, 0.12) end)
            handle.MouseLeave:Connect(function() tw(dot, {BackgroundColor3 = C.divider}, 0.12) end)
        end

        local resizing   = false
        local startMouse = Vector2.new()
        local startSize  = Vector2.new()

        handle.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing   = true
                startMouse = Vector2.new(i.Position.X, i.Position.Y)
                startSize  = Vector2.new(win.Size.X.Offset, win.Size.Y.Offset)
                i.Changed:Connect(function()
                    if i.UserInputState == Enum.UserInputState.End then resizing = false end
                end)
            end
        end)

        UIS.InputChanged:Connect(function(i)
            if resizing and i.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = Vector2.new(i.Position.X, i.Position.Y) - startMouse
                local newW = h.dx ~= 0 and math.max(minW, startSize.X + delta.X * h.dx) or startSize.X
                local newH = h.dy ~= 0 and math.max(minH, startSize.Y + delta.Y * h.dy) or startSize.Y
                win.Size = UDim2.new(0, newW, 0, newH)
            end
        end)
    end
end

