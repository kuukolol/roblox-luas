        label(btn, {
            Text       = "#",
            Size       = UDim2.new(0, 18, 1, 0),
            Position   = UDim2.new(0, 4, 0, 0),
            TextSize   = 16,
            TextColor3 = C.muted,
        })
        local btnLbl = label(btn, {
            Text       = ch.label,
            Size       = UDim2.new(1, -26, 1, 0),
            Position   = UDim2.new(0, 24, 0, 0),
            TextSize   = 13,
            TextColor3 = C.muted,
        })

        btn.MouseEnter:Connect(function()
            if activeChanId ~= ch.id then
                btn.BackgroundTransparency = 0.7
                btnLbl.TextColor3 = C.text
            end
        end)
        btn.MouseLeave:Connect(function()
            if activeChanId ~= ch.id then
                btn.BackgroundTransparency = 1
                btnLbl.TextColor3 = C.muted
            end
        end)

        -- Feed (ScrollingFrame)
        local feed = Instance.new("ScrollingFrame")
        feed.Name                    = "Feed_" .. ch.id
        feed.Size                    = UDim2.new(1, 0, 1, -44)
        feed.Position                = UDim2.new(0, 0, 0, 44)
        feed.BackgroundTransparency  = 1
        feed.BorderSizePixel         = 0
        feed.ScrollBarThickness      = 4
        feed.ScrollBarImageColor3    = C.divider
        feed.ScrollBarImageTransparency = 0.4
        feed.CanvasSize              = UDim2.new(0, 0, 0, 0)
        feed.AutomaticCanvasSize     = Enum.AutomaticSize.Y
        feed.Visible                 = false
        feed.Parent                  = ca

        local fl = Instance.new("UIListLayout")
        fl.Padding = UDim.new(0, 4)
        fl.Parent  = feed
        local fp = Instance.new("UIPadding")
        fp.PaddingLeft   = UDim.new(0, 12)
        fp.PaddingRight  = UDim.new(0, 12)
        fp.PaddingTop    = UDim.new(0, 8)
        fp.PaddingBottom = UDim.new(0, 8)
        fp.Parent        = feed

