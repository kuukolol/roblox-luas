local UI = {}
UI.__index = UI

function UI.new(config)
    config = config or {}
    local self = setmetatable({}, UI)

    local WIN_W  = config.width      or 700
    local WIN_H  = config.height     or 420
    local BAR_H  = 36
    local SIDE_W = 160
    local BOT_H  = 52

    local TITLE    = config.title          or "App"
    local SERVER   = config.serverName     or TITLE
    local ICON     = config.iconImage      or "rbxassetid://6031280882"
    local CHANNELS = config.channels       or {{id = "feed", label = "live-feed"}}
    local DEF_CH   = config.defaultChannel or CHANNELS[1].id
    local UNAME    = config.userName       or LP.DisplayName
    local UTAG     = config.userTag        or ("@" .. LP.Name)

    local sg = Instance.new("ScreenGui")
    sg.Name = "UniversalUI_" .. tostring(math.random(1e5, 9e5))
    sg.ResetOnSpawn = false; sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.Parent = game:GetService("CoreGui")
    self._sg = sg

    local win = frm(sg, {
        Name = "Window", BackgroundColor3 = C.bg,
        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.new(0.5, 0, 0, 60),
        Size = UDim2.new(0, WIN_W, 0, WIN_H),
        ClipsDescendants = true,
    })
    corner(win, 8); self._win = win

    -- Attach resize handles
    makeResizable(win, 480, 260)

    local bar = frm(win, {Name = "TitleBar", BackgroundColor3 = C.sidebar, Size = UDim2.new(1, 0, 0, BAR_H)})

    local titleIco = Instance.new("ImageLabel")
    titleIco.Size = UDim2.new(0, 20, 0, 20); titleIco.Position = UDim2.new(0, 10, 0.5, -10)
    titleIco.BackgroundTransparency = 1; titleIco.Image = ICON; titleIco.ImageColor3 = C.accent; titleIco.Parent = bar

    local titleLbl = lbl(bar, {
        Text = TITLE, Size = UDim2.new(1, -100, 1, 0), Position = UDim2.new(0, 36, 0, 0),
        Font = Enum.Font.GothamBold, TextSize = 14, TextColor3 = C.text,
    })
    self._titleLbl = titleLbl

    local closeBtn, closeIco = imgBtn(bar, {
        Size = UDim2.new(0, 36, 0, BAR_H), Position = UDim2.new(1, -36, 0, 0),
        Image = "rbxassetid://6035047409", IconSize = UDim2.new(0, 16, 0, 16), Color = C.muted,
    })
    closeBtn.MouseEnter:Connect(function() tw(closeIco, {ImageColor3 = C.red}, 0.12) end)
    closeBtn.MouseLeave:Connect(function() tw(closeIco, {ImageColor3 = C.muted}, 0.12) end)
    closeBtn.MouseButton1Click:Connect(function()
        tw(win, {Size = UDim2.new(0, WIN_W, 0, 0)}, 0.22)
        task.delay(0.25, function() sg:Destroy() end)
    end)

    local minBtn, minIco = imgBtn(bar, {
        Size = UDim2.new(0, 36, 0, BAR_H), Position = UDim2.new(1, -72, 0, 0),
        Image = "rbxassetid://6035067836", IconSize = UDim2.new(0, 16, 0, 16), Color = C.muted,
    })
    minBtn.MouseEnter:Connect(function() tw(minIco, {ImageColor3 = C.text}, 0.12) end)
    minBtn.MouseLeave:Connect(function() tw(minIco, {ImageColor3 = C.muted}, 0.12) end)
    makeDraggable(bar, win)

    local cw = frm(win, {
        Name = "ContentWrap", BackgroundColor3 = C.bg,
        Position = UDim2.new(0, 0, 0, BAR_H), Size = UDim2.new(1, 0, 1, -BAR_H),
    })
    local minimised = false
    minBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        if minimised then
            cw.Visible = false; tw(win, {Size = UDim2.new(0, win.Size.X.Offset, 0, BAR_H)}, 0.2)
        else
            tw(win, {Size = UDim2.new(0, win.Size.X.Offset, 0, WIN_H)}, 0.2)
            task.delay(0.21, function() cw.Visible = true end)
        end
    end)

    local sidebar = frm(cw, {Name = "Sidebar", BackgroundColor3 = C.sidebar, Size = UDim2.new(0, SIDE_W, 1, 0)})

    local srvHdr = frm(sidebar, {BackgroundColor3 = C.sidebar, Size = UDim2.new(1, 0, 0, 40)})
    divLine(srvHdr, 39)
    local srvLbl = lbl(srvHdr, {
        Text = "  " .. SERVER, Size = UDim2.new(1, 0, 1, 0),
        Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = C.text,
    })
    self._srvLbl = srvLbl

    local chanList = frm(sidebar, {
        BackgroundColor3 = C.sidebar,
        Position = UDim2.new(0, 0, 0, 46),
        Size = UDim2.new(1, 0, 1, -(46 + BOT_H)),
    })
    local clPad = Instance.new("UIPadding")
    clPad.PaddingLeft = UDim.new(0, 6); clPad.PaddingRight = UDim.new(0, 6); clPad.PaddingTop = UDim.new(0, 4)
    clPad.Parent = chanList
    local clLayout = Instance.new("UIListLayout"); clLayout.Padding = UDim.new(0, 2); clLayout.Parent = chanList

    local bot = frm(sidebar, {
        BackgroundColor3 = Color3.fromRGB(28, 29, 32),
        Position = UDim2.new(0, 0, 1, -BOT_H), Size = UDim2.new(1, 0, 0, BOT_H),
    })
    local avi = Instance.new("ImageLabel")
    avi.Size = UDim2.new(0, 32, 0, 32); avi.Position = UDim2.new(0, 8, 0.5, -16)
    avi.BackgroundColor3 = C.panel; avi.BorderSizePixel = 0
    avi.Image = "rbxthumb://type=AvatarHeadShot&id=" .. LP.UserId .. "&w=100&h=100"; avi.Parent = bot
    corner(avi, 16)

    local botName = lbl(bot, {
        Text = UNAME, Size = UDim2.new(1, -82, 0, 16), Position = UDim2.new(0, 48, 0, 7),
        TextSize = 12, Font = Enum.Font.GothamBold, TextColor3 = C.text,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })
    local botTag = lbl(bot, {
        Text = UTAG, Size = UDim2.new(1, -82, 0, 14), Position = UDim2.new(0, 48, 0, 27),
        TextSize = 10, Font = Enum.Font.Gotham, TextColor3 = C.muted,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })
    self._botName = botName; self._botTag = botTag

    local sp, settingsOpen, gearIcoRef
    settingsOpen = false

    local gearBtn, gearIco = imgBtn(bot, {
        Size = UDim2.new(0, 26, 0, 26), Position = UDim2.new(1, -32, 0.5, -13),
        Image = "rbxassetid://6031280882", IconSize = UDim2.new(0, 18, 0, 18), Color = C.muted,
    })
    corner(gearBtn, 5); gearBtn.BackgroundColor3 = C.panel; gearBtn.BackgroundTransparency = 1
    gearBtn.MouseEnter:Connect(function() tw(gearIco, {ImageColor3 = C.text}, 0.15); tw(gearBtn, {BackgroundTransparency = 0}, 0.15) end)
    gearBtn.MouseLeave:Connect(function() tw(gearIco, {ImageColor3 = C.muted}, 0.15); tw(gearBtn, {BackgroundTransparency = 1}, 0.15) end)
    gearIcoRef = gearIco

    local ca = frm(cw, {
        Name = "ContentArea", BackgroundColor3 = C.bg,
        Position = UDim2.new(0, SIDE_W, 0, 0), Size = UDim2.new(1, -SIDE_W, 1, 0),
    })
    local chanHdr = frm(ca, {BackgroundColor3 = C.bg, Size = UDim2.new(1, 0, 0, 44)})
    divLine(chanHdr, 43)
    lbl(chanHdr, {Text = "#", Size = UDim2.new(0, 20, 1, 0), Position = UDim2.new(0, 14, 0, 0), TextSize = 22, TextColor3 = C.muted})
    local chanHdrTitle = lbl(chanHdr, {
        Text = DEF_CH, Size = UDim2.new(1, -50, 1, 0), Position = UDim2.new(0, 36, 0, 0),
        TextSize = 15, Font = Enum.Font.GothamBold, TextColor3 = C.text,
    })

    local channelData  = {}
    local activeChanId = DEF_CH

    local function switchChannel(id)
        activeChanId = id
        if settingsOpen then
            settingsOpen = false
            if sp then sp.Visible = false end
            tw(gearIcoRef, {ImageColor3 = C.muted}, 0.15)
        end
        for cid, cd in pairs(channelData) do
            cd.feed.Visible = (cid == id)
            if cid == id then
                cd.btn.BackgroundColor3 = C.panel; cd.btn.BackgroundTransparency = 0; cd.btnLbl.TextColor3 = C.text
            else
                cd.btn.BackgroundColor3 = C.sidebar; cd.btn.BackgroundTransparency = 1; cd.btnLbl.TextColor3 = C.muted
            end
        end
        for _, ch in ipairs(CHANNELS) do
            if ch.id == id then chanHdrTitle.Text = ch.label; break end
        end
    end

    for _, ch in ipairs(CHANNELS) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 28); btn.BackgroundColor3 = C.sidebar
        btn.BackgroundTransparency = 1; btn.AutoButtonColor = false
        btn.Font = Enum.Font.Gotham; btn.Text = ""; btn.Parent = chanList
        corner(btn, 4)
        lbl(btn, {Text = "#", Size = UDim2.new(0, 18, 1, 0), Position = UDim2.new(0, 4, 0, 0), TextSize = 16, TextColor3 = C.muted})
        local btnLbl = lbl(btn, {Text = ch.label, Size = UDim2.new(1, -26, 1, 0), Position = UDim2.new(0, 24, 0, 0), TextSize = 13, TextColor3 = C.muted})
        btn.MouseEnter:Connect(function()
            if activeChanId ~= ch.id then btn.BackgroundTransparency = 0.7; btnLbl.TextColor3 = C.text end
        end)
        btn.MouseLeave:Connect(function()
            if activeChanId ~= ch.id then btn.BackgroundTransparency = 1; btnLbl.TextColor3 = C.muted end
        end)

        local feed = Instance.new("ScrollingFrame")
        feed.Name = "Feed_" .. ch.id; feed.Size = UDim2.new(1, 0, 1, -44); feed.Position = UDim2.new(0, 0, 0, 44)
        feed.BackgroundTransparency = 1; feed.BorderSizePixel = 0; feed.ScrollBarThickness = 4
        feed.ScrollBarImageColor3 = C.divider; feed.ScrollBarImageTransparency = 0.4
        feed.CanvasSize = UDim2.new(0, 0, 0, 0); feed.AutomaticCanvasSize = Enum.AutomaticSize.Y
        feed.Visible = false; feed.Parent = ca
        local fl = Instance.new("UIListLayout"); fl.Padding = UDim.new(0, 4); fl.Parent = feed
        local fp = Instance.new("UIPadding")
        fp.PaddingLeft = UDim.new(0, 12); fp.PaddingRight = UDim.new(0, 12)
        fp.PaddingTop = UDim.new(0, 8); fp.PaddingBottom = UDim.new(0, 8); fp.Parent = feed
        channelData[ch.id] = {btn = btn, btnLbl = btnLbl, feed = feed, feedLayout = fl}
        local capId = ch.id
        btn.MouseButton1Click:Connect(function() switchChannel(capId) end)
    end

    switchChannel(DEF_CH)
    self._channelData = channelData
    self._feed = channelData[DEF_CH].feed
    self._feedLayout = channelData[DEF_CH].feedLayout

    -- ── Settings panel ────────────────────────────────────────────────────────
    sp = frm(cw, {
        Name = "SettingsPanel", BackgroundColor3 = C.bg,
        Position = UDim2.new(0, SIDE_W, 0, 0), Size = UDim2.new(1, -SIDE_W, 1, 0),
        Visible = false, ZIndex = 10,
    })
    local spHdr = frm(sp, {BackgroundColor3 = C.bg, Size = UDim2.new(1, 0, 0, 44), ZIndex = 10})
    divLine(spHdr, 43)
    lbl(spHdr, {Text = "#", Size = UDim2.new(0, 20, 1, 0), Position = UDim2.new(0, 14, 0, 0), TextSize = 22, TextColor3 = C.muted, ZIndex = 11})
    lbl(spHdr, {Text = "settings", Size = UDim2.new(1, -50, 1, 0), Position = UDim2.new(0, 36, 0, 0), TextSize = 15, Font = Enum.Font.GothamBold, TextColor3 = C.text, ZIndex = 11})

    local spBody = frm(sp, {BackgroundColor3 = C.bg, Position = UDim2.new(0, 0, 0, 44), Size = UDim2.new(1, 0, 1, -44), ZIndex = 10})
    local spPad = Instance.new("UIPadding")
    spPad.PaddingLeft = UDim.new(0, 20); spPad.PaddingRight = UDim.new(0, 20); spPad.PaddingTop = UDim.new(0, 16)
    spPad.Parent = spBody

    lbl(spBody, {Text = "PROFILE", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 0),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})

    local pc = frm(spBody, {BackgroundColor3 = Color3.fromRGB(28, 29, 32),
        Position = UDim2.new(0, 0, 0, 22), Size = UDim2.new(1, 0, 0, 60), ZIndex = 10})
    corner(pc, 8)
    local pcAvi = Instance.new("ImageLabel")
    pcAvi.Size = UDim2.new(0, 38, 0, 38); pcAvi.Position = UDim2.new(0, 10, 0.5, -19)
    pcAvi.BackgroundColor3 = C.panel; pcAvi.BorderSizePixel = 0; pcAvi.ZIndex = 11
    pcAvi.Image = "rbxthumb://type=AvatarHeadShot&id=" .. LP.UserId .. "&w=100&h=100"
    pcAvi.Parent = pc; corner(pcAvi, 19)
    local pcName = lbl(pc, {Text = UNAME, Size = UDim2.new(1, -70, 0, 18), Position = UDim2.new(0, 58, 0, 10),
        TextSize = 13, Font = Enum.Font.GothamBold, TextColor3 = C.text, ZIndex = 11})
    local pcTag  = lbl(pc, {Text = UTAG, Size = UDim2.new(1, -70, 0, 14), Position = UDim2.new(0, 58, 0, 32),
        TextSize = 11, Font = Enum.Font.Gotham, TextColor3 = C.muted, ZIndex = 11})

    lbl(spBody, {Text = "DISPLAY NAME", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 96),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})
    local nameIn, _ = styledInput(spBody, {Size = UDim2.new(1, 0, 0, 36), Position = UDim2.new(0, 0, 0, 116),
        Default = UNAME, Placeholder = "Display name...", ZIndex = 10})
    nameIn:GetPropertyChangedSignal("Text"):Connect(function()
        local v = nameIn.Text ~= "" and nameIn.Text:sub(1, 24) or UNAME
        pcName.Text = v; botName.Text = v
    end)

    lbl(spBody, {Text = "USERNAME", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 164),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})
    local userIn, _ = styledInput(spBody, {Size = UDim2.new(1, 0, 0, 36), Position = UDim2.new(0, 0, 0, 184),
        Default = LP.Name, Placeholder = "Username...", ZIndex = 10})
    userIn:GetPropertyChangedSignal("Text"):Connect(function()
        if userIn.Text ~= "" then
            pcTag.Text  = "@" .. userIn.Text
            botTag.Text = "@" .. userIn.Text
        end
    end)

    lbl(spBody, {Text = "APPEARANCE", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 234),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})
    lbl(spBody, {Text = "WINDOW TITLE", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 258),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})
    local titleIn, _ = styledInput(spBody, {Size = UDim2.new(1, 0, 0, 36), Position = UDim2.new(0, 0, 0, 278),
        Default = TITLE, Placeholder = "Window title...", ZIndex = 10})
    titleIn:GetPropertyChangedSignal("Text"):Connect(function()
        if titleIn.Text ~= "" then titleLbl.Text = titleIn.Text end
    end)

    lbl(spBody, {Text = "SERVER NAME", Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 328),
        TextSize = 10, Font = Enum.Font.GothamBold, TextColor3 = C.muted, ZIndex = 11})
    local srvIn, _ = styledInput(spBody, {Size = UDim2.new(1, 0, 0, 36), Position = UDim2.new(0, 0, 0, 348),
        Default = SERVER, Placeholder = "Server name...", ZIndex = 10})
    srvIn:GetPropertyChangedSignal("Text"):Connect(function()
        if srvIn.Text ~= "" then srvLbl.Text = "  " .. srvIn.Text end
    end)

    local saveBtn = Instance.new("TextButton")
    saveBtn.Size = UDim2.new(1, 0, 0, 36); saveBtn.Position = UDim2.new(0, 0, 0, 400)
    saveBtn.BackgroundColor3 = C.accent; saveBtn.BorderSizePixel = 0; saveBtn.AutoButtonColor = false
    saveBtn.Font = Enum.Font.GothamBold; saveBtn.TextSize = 13
    saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255); saveBtn.Text = "Save Changes"
    saveBtn.ZIndex = 11; saveBtn.Parent = spBody; corner(saveBtn, 6)
    saveBtn.MouseEnter:Connect(function() tw(saveBtn, {BackgroundColor3 = Color3.fromRGB(71, 82, 196)}, 0.15) end)
    saveBtn.MouseLeave:Connect(function() tw(saveBtn, {BackgroundColor3 = C.accent}, 0.15) end)
    saveBtn.MouseButton1Click:Connect(function()
        local nm  = nameIn.Text ~= "" and nameIn.Text:sub(1, 24) or UNAME
        local usr = userIn.Text ~= "" and ("@" .. userIn.Text)   or UTAG
        local ttl = titleIn.Text ~= "" and titleIn.Text           or TITLE
        local srv = srvIn.Text ~= ""   and srvIn.Text             or SERVER
        botName.Text = nm;  botTag.Text = usr
        pcName.Text  = nm;  pcTag.Text  = usr
        titleLbl.Text = ttl; srvLbl.Text = "  " .. srv
        tw(saveBtn, {BackgroundColor3 = C.green}, 0.1)
        task.delay(0.9, function() tw(saveBtn, {BackgroundColor3 = C.accent}, 0.3) end)
    end)

    gearBtn.MouseButton1Click:Connect(function()
        settingsOpen = not settingsOpen
        sp.Visible = settingsOpen
        tw(gearIco, {ImageColor3 = settingsOpen and C.accent or C.muted}, 0.15)
    end)

    return self
end

