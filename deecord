local UI = {}
UI.__index = UI

--[[
    config = {
        title      = "My App",          -- window title bar text
        serverName = "My Server",       -- sidebar server name
        iconImage  = "rbxassetid://...",-- optional icon next to title
        width      = 700,               -- optional
        height     = 420,               -- optional
        channels   = {                  -- list of channels (in order)
            { id = "feed",     label = "live-feed" },
            { id = "logs",     label = "logs"      },
        },
        defaultChannel = "feed",        -- which channel is active on open
        userName   = LP.DisplayName,    -- bottom bar display name
        userTag    = "@" .. LP.Name,    -- bottom bar tag
    }
--]]
