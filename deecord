function UI:AddEntry(config)
    config = config or {}
    local cd   = config.channelId and self._channelData[config.channelId] or nil
    local feed = cd and cd.feed or self._feed
    if not feed then return end

    local accentClr = config.accentColor or C.muted
    local cardH     = config.cardHeight  or 138
    local fields    = config.fields      or {}
    local hasVP     = config.onViewport  ~= nil
    local VP_SIZE   = 88
    local TEXT_X    = 14
    -- Scale-based right padding: responsive to any window width
    local rightPad  = hasVP and (VP_SIZE + 80) or 8

    local card = Instance.new("Frame")
    card.Name = "UICard"; card.Size = UDim2.new(1, 0, 0, cardH)
    card.BackgroundColor3 = Color3.fromRGB(30, 31, 35); card.BorderSizePixel = 0
    card.Parent = feed; corner(card, 6)

    local accent = Instance.new("Frame")
    accent.Size = UDim2.new(0, 4, 1, 0); accent.BackgroundColor3 = accentClr
    accent.BorderSizePixel = 0; accent.Parent = card; corner(accent, 4)
    local accentFill = Instance.new("Frame")
    accentFill.Size = UDim2.new(0, 2, 1, 0); accentFill.Position = UDim2.new(0, 2, 0, 0)
    accentFill.BackgroundColor3 = accentClr; accentFill.BorderSizePixel = 0; accentFill.Parent = card

    for i, field in ipairs(fields) do
        local yPos = 10 + (i - 1) * 32
        local fl = Instance.new("TextLabel")
        fl.Size = UDim2.new(1, -(TEXT_X + rightPad), 0, 14); fl.Position = UDim2.new(0, TEXT_X, 0, yPos)
        fl.BackgroundTransparency = 1; fl.Font = Enum.Font.GothamBold; fl.TextSize = 10
        fl.TextColor3 = Color3.fromRGB(148, 155, 164); fl.TextXAlignment = Enum.TextXAlignment.Left
        fl.Text = (field.label or ""):upper(); fl.Parent = card
        local fv = Instance.new("TextLabel")
        fv.Size = UDim2.new(1, -(TEXT_X + rightPad), 0, 16); fv.Position = UDim2.new(0, TEXT_X, 0, yPos + 14)
        fv.BackgroundTransparency = 1; fv.Font = Enum.Font.GothamSemibold; fv.TextSize = 13
        fv.TextColor3 = field.color or Color3.fromRGB(220, 221, 222)
        fv.TextXAlignment = Enum.TextXAlignment.Left; fv.TextTruncate = Enum.TextTruncate.AtEnd
        fv.Text = tostring(field.value or ""); fv.Parent = card
    end

    if config.button then
        -- Send Trade button
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 120, 0, 22); btn.Position = UDim2.new(0, TEXT_X, 0, cardH - 30)
        btn.BackgroundColor3 = Color3.fromRGB(60, 63, 70); btn.BorderSizePixel = 0
        btn.AutoButtonColor = false; btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(220, 221, 222); btn.Text = config.button.text or "Action"
        btn.Parent = card; corner(btn, 4)
        btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(75, 78, 88) end)
        btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(60, 63, 70) end)
        if config.button.onClick then btn.MouseButton1Click:Connect(config.button.onClick) end

        -- Remove button (right of Send Trade)
        local removeBtn = Instance.new("TextButton")
        removeBtn.Size = UDim2.new(0, 72, 0, 22)
        removeBtn.Position = UDim2.new(0, TEXT_X + 124, 0, cardH - 30)
        removeBtn.BackgroundColor3 = Color3.fromRGB(60, 35, 35); removeBtn.BorderSizePixel = 0
        removeBtn.AutoButtonColor = false; removeBtn.Font = Enum.Font.GothamSemibold; removeBtn.TextSize = 11
        removeBtn.TextColor3 = Color3.fromRGB(240, 71, 71); removeBtn.Text = "Remove"
        removeBtn.Parent = card; corner(removeBtn, 4)
        removeBtn.MouseEnter:Connect(function() removeBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 40) end)
        removeBtn.MouseLeave:Connect(function() removeBtn.BackgroundColor3 = Color3.fromRGB(60, 35, 35) end)
        removeBtn.MouseButton1Click:Connect(function()
            card:Destroy()
        end)
    end

    if config.onViewport then
        local vp = Instance.new("ViewportFrame")
        vp.Size = UDim2.new(0, VP_SIZE, 0, VP_SIZE); vp.Position = UDim2.new(0.65, 0, 0.5, -(VP_SIZE / 2))
        vp.BackgroundColor3 = Color3.fromRGB(20, 21, 24); vp.BorderSizePixel = 0
        vp.LightColor = Color3.fromRGB(230, 235, 255); vp.LightDirection = Vector3.new(-1, -2, -1)
        vp.Ambient = Color3.fromRGB(180, 180, 180); vp.Parent = card; corner(vp, 6)
        local cam = Instance.new("Camera"); cam.FieldOfView = 28; cam.Parent = vp; vp.CurrentCamera = cam
        local wm = Instance.new("WorldModel"); wm.Parent = vp
        config.onViewport(vp, wm, cam)
    end

    feed.CanvasPosition = Vector2.new(0, math.huge)
    return card
end

function UI:GetFeed(channelId)
    if channelId and self._channelData[channelId] then
        return self._channelData[channelId].feed
    end
    return self._feed
end

function UI:UpdateTimestamps()
    for _, cd in pairs(self._channelData) do
        for _, row in cd.feed:GetChildren() do
            if row:IsA("Frame") then
                local sa = row:GetAttribute("SpawnedAt")
                if sa then
                    local e = math.floor(os.clock() - sa)
                    local t
                    if e < 60 then t = e .. "s ago"
                    elseif e < 3600 then
                        local m = math.floor(e / 60); local s = e % 60
                        t = s > 0 and (m .. "m " .. s .. "s ago") or (m .. "m ago")
                    else t = math.floor(e / 3600) .. "h ago" end
                    for _, l in row:GetDescendants() do
                        if l:IsA("TextLabel") and l.Name == "TimeLabel" then l.Text = t end
                    end
                end
            end
        end
    end
end

return UI
